---
import MainHead from "../components/MainHead.astro";
import Header from "../components/Header.vue";
import Footer from "../components/Footer.astro";
---

<html lang="en">
	<head>
		<MainHead title="LUKA" description="Description"/>
		<style>
			body { width: 100%; height: 100%; display: flex; flex-flow: column wrap; align-items: center; }

			.main {
				display: flex;
				flex-flow: column wrap;
				justify-content: center;
				align-items: center;
				box-shadow: var(--shadow);
				background: var(--bg-highlight);
				margin: 1.5rem;
				padding: 1.5rem;
			}

			h1 { margin: 0 0 30px 0 }
			h2 { margin: 0 0 0 0 }

			.accent {
				position: relative;
				color: var(--accent);
				z-index: 99;
				font-weight: bold;
			}

			.accent::before {
				content: "Luka";
				position: absolute;
				color: var(--bg);
				z-index: -1;
				font-size: 2.1rem;
				left: var(--text-shadow-left);
				top: var(--text-shadow-top);
				transition: all var(--std-transition);
			}

			a {
				color: var(--cl);
				text-decoration: solid underline 3px var(--accent);
			}

			a:hover {
				color: var(--accent);
				text-decoration-color: var(--cl);
			}

			.lang { font-weight: 800; }
			.ruby { color: var(--ruby-accent); }
			.js { color: var(--accent) }
			.logo { height: 12px; user-select: none; }
			.ruby img { height: 10px; }

			.subtext { display: flex; flex-flow: column wrap; align-items: center; }
			p { font-size: 1.2rem; margin: 10px 0; }
		</style>
	</head>

	<body>
		<Header client:load />

		<div class="main">
			<h1>hi there, i'm <span class="accent">Luka</span></h1>
			<h2>i'm a fullstack web developer, currently working at <a href="https://feedbackfruits.com" target="_blank">feedbackfruits</a> in amsterdam</h2>
		</div>
		
		<div class="subtext">
			<p>i love building cool stuff, especially with <span class="ruby lang"><img class="logo" src="/assets/ruby.svg" aria-hidden="true"> ruby</span> and <span class="js lang"><img class="logo" src="/assets/js.svg" aria-hidden="true"> javascript</span></p>
			<p>if you'd like to see my professional history, you can get <a href="/assets/resume.pdf" download="Luka's Resume">my resume here</a></p>
			<p>if you're still curious and want to find out more or even just want to touch base, feel free to <a href="/contact" target="_blank">contact</a> me</p>
		</div>

		<Footer client:visible />
	</body>
</html>
