---
interface Props {
  route: string;
  newTab: boolean;
}

const { route, newTab = false } = Astro.props;

const path = new URL(Astro.request.url).pathname;
const isActiveRoute = path === route;
---

<a class:list={[{ active: isActiveRoute }]} href={route} target={newTab ? "_blank" : ""} rel="noopener">
  <slot />
</a>

<style>
  a {
    @apply mx-1.5 font-bold underline decoration-accent decoration-3 hover:text-accent hover:decoration-cl;
  }

  a.active {
    @apply text-accent decoration-transparent;
  }
</style>
