---
import ThemeToggle from "@/components/Base/ThemeToggle.vue";

const path = new URL(Astro.request.url).pathname;
---

<header class="grid grid-cols-3 w-full items-center bg-highlight py-2 px-4 transition-colors">
  <h1 class="font-black text-lg">luka salević</h1>

  <nav class="mx-auto">
    <a class={path === '/' ? 'active' : ''} href="/">home</a>
    <a class={path === '/shenanigans' ? 'active' : '' } href="/shenanigans">shenanigans</a>
  </nav>

  <ThemeToggle client:only="vue" />
</header>

<style>
  a {
    @apply mx-1.5 font-bold underline decoration-2 decoration-accent hover:text-accent hover:decoration-cl;
  }

  a.active {
    @apply text-accent decoration-transparent;
  }
</style>
